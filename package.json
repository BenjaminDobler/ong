{
  "name": "@richapps/ong",
  "version": "0.1.20",
  "description": "Angular CLI powered by Vite + OXC — blazing fast drop-in replacement for ng serve/build",
  "keywords": [
    "angular",
    "vite",
    "oxc",
    "cli",
    "compiler",
    "nx",
    "build",
    "dev-server"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "ong": "./bin/ong.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@oxc-angular/vite": "^0.0.17",
    "angular-html-parser": "^10.4.0"
  },
  "peerDependencies": {
    "vite": ">=8.0.0-beta.10"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.0-beta.16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BenjaminDobler/ong"
  }
}
